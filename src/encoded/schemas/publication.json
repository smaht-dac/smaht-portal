{
    "title": "Publication",
    "description": "Consortium publications",
    "$id": "/profiles/publication.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
        "doi"
    ],
    "anyOf": [
        {
            "required": [
                "submission_centers"
            ]
        },
        {
            "required": [
                "consortia"
            ]
        }
    ],
    "identifyingProperties": [
        "accession",
        "aliases",
        "uuid"        
    ],
    "additionalProperties": false,
    "mixinProperties": [
        {
            "$ref": "mixins.json#/accession"
        },
        {
            "$ref": "mixins.json#/aliases"
        },
        {
            "$ref": "mixins.json#/attribution"
        },
        {
            "$ref": "mixins.json#/modified"
        },
        {
            "$ref": "mixins.json#/schema_version"
        },
        {
            "$ref": "mixins.json#/static_embeds"
        },
        {
            "$ref": "mixins.json#/status"
        },
        {
            "$ref": "mixins.json#/submitted"
        },
        {
            "$ref": "mixins.json#/tags"
        },
        {   
            "$ref": "mixins.json#/uuid"
        }
    ],
    "properties": {
        "schema_version": {
            "default": "1"
        },
        "accession": {
            "accessionType": "PB"
        },
        "doi": {
            "title": "DOI",
            "description": "DOI for the publication or preprint",
            "type": "string",
            "comment": "Please provide in the form of 10.1234/abc123"
        },
        "pubmed_id":{
            "title": "Publication Identifier",
            "description": "PMID for the publication (if available).",
            "type": "string"
        },
        "title": {
            "title": "Title",
            "description": "Title of the article",
            "type": "string",
            "permission": "restricted_fields"
        },
        "abstract": {
            "title": "Abstract",
            "description": "Abstract of the publication.",
            "type": "string",
            "permission": "restricted_fields",
            "formInput": "textarea"
        },
        "authors": {
            "title": "Authors",
            "description": "All authors, with format Bernstein BE, Birney E, Dunham I,...",
            "type": "array",
            "items": {
                "title": "Author",
                "type": "object",
                "additionalProperties": false,
                "required": ["last_name"],
                "uniqueItems": true,
                "properties": {
                    "first_name": {
                        "title": "Given name and/or initials",
                        "description": "An author's given (first) name and optional middle initial - or initials if that is only option",
                        "type": "string"
                    },
                    "last_name": {
                        "title": "Surname",
                        "description": "An author's surname (last name)",
                        "type": "string"
                    }
                }
            },
            "permission": "restricted_fields"
        },
        "code_repositories": {
            "title": "Code Repositories",
            "description": "Links to code repositories associated with this publication.",
            "type": "array",
            "items": {
                "type": "string",
                "format": "uri"
            }
        },
        "date_published": {
            "title": "Publication Date",
            "type": "string",
            "permission": "restricted_fields"
        },
        "is_preprint": {
            "title": "Is Preprint",
            "description": "Indicates whether the publication is a preprint.",
            "type": "boolean",
            "permission": "restricted_fields"
        },        
        "journal": {
            "title": "Journal",
            "description": "Name of the journal in which the article was published.",
            "type": "string",
            "permission": "restricted_fields"
        },
        "journal_url": {
            "title": "Journal URL",
            "description": "Link to the paper on the publishing journal web site.",
            "type": "string",
            "format": "uri",
            "permission": "restricted_fields"
        },
        "key_image_link": {
            "title": "Key Image Link",
            "description": "URL link to the full image file from a key figure from the paper - usually Fig. 1",
            "type": "string",
            "format": "uri"
        },
        "key_image_thumbnail_link": {
            "title": "Key Image Thumbnail Link",
            "description": "URL link to a thumbnail image from a key figure from the paper - usually Fig. 1 or part thereof",
            "type": "string",
            "format": "uri"
        },
        "repository_urls": {
            "title": "Repository URLs",
            "description": "Link to the paper in the repositories (e.g. bioRxiv, PubMed).",
            "comment": "Preprints can be indexed in pubmed and an arxiv server",
            "type": "array",
            "items": {
                "type": "string",
                "title": "Repository Link",
                "format": "uri"
            },
            "permission": "restricted_fields"
        },
        "preprint_version": {
            "title": "Version",
            "description": "Version of the record as it appears in the external database (e.g. bioRxiv version)",
            "type": "string",
            "permission": "restricted_fields"
        },
        "previous_repository_urls": {
            "title": "Previous Repository URLs",
            "description": "Links to previous versions of the publication in external repositories.",
            "type": "array",
            "items": {
                "type": "string",
                "format": "uri"
            },
            "permission": "restricted_fields"
        },
        "publication_groups": {
            "title": "Publication Group(s)",
            "description": "Field to specify this publication as belonging to specific group(s).",
            "type": "array",
            "items": {
                "type": "string",
                "suggested_enum": [
                    "Benchmarking",
                    "Production",
                    "P25"
                ]
            },
            "permission": "restricted_fields"
        },
        "scope": {
            "title": "Scope",
            "description": "Scope of the publication.",
            "type": "string",
            "enum": ["Working group", "Network", "Individual Lab"]
        },
        "working_group_name": {
            "title": "Working Group Name",
            "description": "For publications with scope 'Working group', the name of the WG that produced the publication",
            "type": "string",
            "enum": [
                "SNV/Indel",
                "SV",
                "MEI",
                "Genome Assembly",
                "Duplex-Seq",
                "Single-cell",
                "Functional"
            ]
        }
    },
    "facets": {
        "journal": {
            "title": "Journal"
        },
        "authors.last_name": {
            "title": "Authors"
        },
        "date_published": {
            "title": "Year"
        }
    },
    "columns": {
        "title": {
            "title": "Title"
        },
        "short_citation": {
            "title": "Short Citation"
        },
        "date_published": {
            "title": "Year"
        },
        "journal": {
            "title": "Journal"
        }
    }
}
